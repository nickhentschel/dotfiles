{{- $email := promptString "email" -}}
{{- /* Detect macOS appearance mode */ -}}
{{- $appearance := "dark" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $appleStyle := output "defaults" "read" "-g" "AppleInterfaceStyle" | trim -}}
{{-   if eq $appleStyle "Dark" -}}
{{-     $appearance = "dark" -}}
{{-   else -}}
{{-     $appearance = "light" -}}
{{-   end -}}
{{- end -}}
{{- /* Work detection: Zillow email domain or ZG- hostname prefix */ -}}
{{- $isWork := or (hasSuffix "@zillowgroup.com" $email) (hasPrefix "ZG-" .chezmoi.hostname) -}}

[data]
  email = "{{ $email }}"
  name = "Nick Hentschel"
  appearance_mode = "{{ $appearance }}"
  isWork = {{ $isWork }}
