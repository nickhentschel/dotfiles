{{- /* openclaw.json.tmpl — managed by chezmoi
   Required Keychain entries (service=openclaw):
     account=gateway_token         gateway auth token
     account=telegram_bot_token    Telegram bot token
     account=tailscale_hostname    machine hostname in tailnet (e.g. "my-mac.tail.ts.net")
     account=telegram_group_id     Telegram group ID (negative number, e.g. "-1003982690496")
     account=telegram_allow_from   Telegram user ID allowed to chat
     account=voyage_api_key        Voyage AI API key (for memory search embeddings)

   Seed on a fresh system (run: openclaw-seed-keychain):
     security add-generic-password -U -s openclaw -a gateway_token -w '<value>'
     security add-generic-password -U -s openclaw -a telegram_bot_token -w '<value>'
     security add-generic-password -U -s openclaw -a tailscale_hostname -w '<value>'
     security add-generic-password -U -s openclaw -a telegram_group_id -w '<value>'
     security add-generic-password -U -s openclaw -a telegram_allow_from -w '<value>'
     security add-generic-password -U -s openclaw -a voyage_api_key -w '<value>'
*/ -}}
{
  "meta": {
    "lastTouchedVersion": "2026.4.26",
    "lastTouchedAt": "2026-04-30T13:38:00.240Z"
  },
  "wizard": {
    "lastRunAt": "2026-04-23T17:47:47.998Z",
    "lastRunVersion": "2026.4.21",
    "lastRunCommand": "configure",
    "lastRunMode": "local"
  },
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "default"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "workspace": "{{ .chezmoi.homeDir }}/clawd",
      "models": {
        "anthropic/claude-opus-4-7": {
          "alias": "opus"
        },
        "anthropic/claude-sonnet-4-6": {},
        "anthropic/claude-haiku-4-5": {}
      },
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "anthropic/claude-haiku-4-5"
        ]
      },
      "contextInjection": "always",
      "bootstrapMaxChars": 20000,
      "bootstrapTotalMaxChars": 150000,
      "imageModel": "anthropic/claude-sonnet-4-6",
      "memorySearch": {
        "provider": "voyage",
        "remote": {
          "apiKey": "{{ (output "security" "find-generic-password" "-s" "openclaw" "-a" "voyage_api_key" "-w") | trim }}"
        }
      }
    }
  },
  "messages": {
    "ackReactionScope": "all"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "{{ (output "security" "find-generic-password" "-s" "openclaw" "-a" "gateway_token" "-w") | trim }}"
    },
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "trustedProxies": [
      "127.0.0.1"
    ],
    "tailscale": {
      "mode": "serve",
      "resetOnExit": true
    },
    "controlUi": {
      "allowedOrigins": [
        "https://{{ (output "security" "find-generic-password" "-s" "openclaw" "-a" "tailscale_hostname" "-w") | trim }}"
      ]
    }
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "searxng",
        "maxResults": 5,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      },
      "fetch": {
        "enabled": true,
        "timeoutSeconds": 45,
        "cacheTtlMinutes": 60
      }
    },
    "deny": [
      "gateway"
    ],
    "exec": {
      "ask": "off",
      "strictInlineEval": true,
      "timeoutSec": 120
    },
    "elevated": {
      "enabled": false
    },
    "fs": {
      "workspaceOnly": false
    }
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "logging": {
    "redactSensitive": "tools"
  },
  "plugins": {
    "entries": {
      "anthropic": {
        "enabled": true
      },
      "searxng": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "http://127.0.0.1:8080"
          }
        }
      },
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "{{ (output "security" "find-generic-password" "-s" "openclaw" "-a" "telegram_bot_token" "-w") | trim }}",
      "groups": {
        "{{ (output "security" "find-generic-password" "-s" "openclaw" "-a" "telegram_group_id" "-w") | trim }}": {
          "groupPolicy": "open",
          "requireMention": false,
          "allowFrom": [
            "{{ (output "security" "find-generic-password" "-s" "openclaw" "-a" "telegram_allow_from" "-w") | trim }}"
          ]
        }
      }
    }
  },
  "mcp": {
    "servers": {
      "google-workspace": {
        "command": "gws-mcp-server",
        "args": [
          "--services",
          "gmail,calendar"
        ],
        "env": {
          "GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND": "file"
        }
      }
    }
  }
}
