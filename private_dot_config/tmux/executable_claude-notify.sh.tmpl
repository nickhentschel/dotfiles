#!/usr/bin/env bash
# claude-notify.sh - Enhanced notifications with agent context
# Shows agent ID, state, tool, and pane information

set -euo pipefail

AGENT_ID="${CLAUDE_SESSION_ID:-unknown}"
NOTIF_TYPE="${CLAUDE_NOTIFICATION_TYPE:-general}"
TOOL="${CLAUDE_TOOL_NAME:-}"
PANE="${TMUX_PANE:-unknown}"
SHORT_ID="${AGENT_ID: -8}"

# Build notification message
case "$NOTIF_TYPE" in
    permission_prompt)
        TITLE="Claude Code - Permission Required"
        MESSAGE="Agent ${SHORT_ID} in pane ${PANE} needs permission"
        SOUND="Submarine"
        ;;
    error)
        TITLE="Claude Code - Error"
        MESSAGE="Agent ${SHORT_ID} in pane ${PANE} encountered an error"
        SOUND="Basso"
        ;;
    tool_complete)
        TITLE="Claude Code - Tool Complete"
        MESSAGE="Agent ${SHORT_ID} in pane ${PANE} completed ${TOOL}"
        SOUND="Ping"
        ;;
    *)
        TITLE="Claude Code"
        MESSAGE="Agent ${SHORT_ID} in pane ${PANE} needs attention"
        SOUND="Ping"
        ;;
esac

# Add tool info if available
if [ -n "$TOOL" ] && [ "$NOTIF_TYPE" != "tool_complete" ]; then
    MESSAGE="${MESSAGE} (${TOOL})"
fi

# Send OS-specific notification
{{- if eq .chezmoi.os "darwin" }}
# macOS notification
osascript -e "display notification \"${MESSAGE}\" with title \"${TITLE}\" sound name \"${SOUND}\""
{{- else }}
# Linux notification
if command -v notify-send >/dev/null 2>&1; then
    notify-send -u normal "${TITLE}" "${MESSAGE}"
fi
{{- end }}

