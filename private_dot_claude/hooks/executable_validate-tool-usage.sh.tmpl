#!/bin/bash
# Pre-tool-use hook to enforce native tool usage over Bash alternatives
# Called before every tool execution with: TOOL_NAME TOOL_ARGS

TOOL_NAME="$1"
TOOL_ARGS="$2"

# Only validate Bash tool usage
if [[ "$TOOL_NAME" != "Bash" ]]; then
    exit 0
fi

# Extract the command from JSON args (tool args are JSON-encoded)
COMMAND=$(echo "$TOOL_ARGS" | jq -r '.command // empty' 2>/dev/null)

if [[ -z "$COMMAND" ]]; then
    COMMAND="$TOOL_ARGS"
fi

block() {
    echo "❌ BLOCKED: $1"
    echo "   $2"
    exit 1
}

# ── File reading ──────────────────────────────────────────────────────────────
# Block cat/head/tail/less/bat at command start OR inside subshells/loops
if echo "$COMMAND" | grep -qE '^[[:space:]]*(cat|head|tail|less|bat)[[:space:]]'; then
    block "Use Read tool instead of $(echo "$COMMAND" | grep -oE '(cat|head|tail|less|bat)' | head -1)" \
          "Read files with the Read tool, not shell commands"
fi
if echo "$COMMAND" | grep -qE '\$\((cat|head|tail|less|bat)[[:space:]]'; then
    block "Use Read tool — blocked cat/head/tail in command substitution \$(...)" \
          "Read files with the Read tool, not shell commands"
fi
if echo "$COMMAND" | grep -qE '(&&|\|\||;|do)[[:space:]]*(cat|head|tail|less|bat)[[:space:]]'; then
    block "Use Read tool — blocked cat/head/tail in sequential command or loop body" \
          "Read files with the Read tool, not shell commands"
fi

# ── File searching ────────────────────────────────────────────────────────────
# Block grep/rg at command start OR inside subshells/loops
if echo "$COMMAND" | grep -qE '^[[:space:]]*(grep|rg|ag|ack)[[:space:]]'; then
    block "Use Grep tool instead of grep/rg/ag" \
          "Search file contents with the Grep tool"
fi
if echo "$COMMAND" | grep -qE '\$\((grep|rg|ag|ack)[[:space:]]'; then
    block "Use Grep tool — blocked grep/rg in command substitution \$(...)" \
          "Search file contents with the Grep tool"
fi
if echo "$COMMAND" | grep -qE '(&&|\|\||;|do)[[:space:]]*(grep|rg|ag|ack)[[:space:]]'; then
    block "Use Grep tool — blocked grep/rg in sequential command or loop body" \
          "Search file contents with the Grep tool"
fi

# ── File listing ──────────────────────────────────────────────────────────────
# Block ALL ls variants (not just ls -R), find, and tree
if echo "$COMMAND" | grep -qE '^[[:space:]]*(find|tree)[[:space:]]'; then
    block "Use Glob tool instead of find/tree" \
          "Find files with the Glob tool"
fi
if echo "$COMMAND" | grep -qE '^[[:space:]]*ls(\s|$)'; then
    block "Use Glob tool instead of ls" \
          "List/find files with the Glob tool"
fi
if echo "$COMMAND" | grep -qE '\$\((find|ls|tree)(\s|[)])'; then
    block "Use Glob tool — blocked find/ls/tree in command substitution \$(...)" \
          "Find files with the Glob tool"
fi
if echo "$COMMAND" | grep -qE '(&&|\|\||;|do)[[:space:]]*(find|ls|tree)(\s|$)'; then
    block "Use Glob tool — blocked find/ls/tree in sequential command or loop body" \
          "Find files with the Glob tool"
fi

# ── File editing ──────────────────────────────────────────────────────────────
if echo "$COMMAND" | grep -qE '^[[:space:]]*(sed|awk)[[:space:]].*-i'; then
    block "Use Edit tool instead of sed/awk -i" \
          "Edit files with the Edit tool"
fi

# ── File creation ─────────────────────────────────────────────────────────────
if echo "$COMMAND" | grep -qE '(cat[[:space:]]+>|cat.*<<|echo[[:space:]].*>>|echo[[:space:]].*>)'; then
    block "Use Write tool instead of cat/echo with redirects or heredocs" \
          "Create files with the Write tool"
fi
if echo "$COMMAND" | grep -qE '(python[0-9]?[[:space:]]+<<|ruby[[:space:]]+<<|node[[:space:]]+<<|perl[[:space:]]+<<)'; then
    block "Use Write tool to create the script file, then run it with Bash" \
          "Write → create .py/.rb/.js file, then Bash → execute it"
fi

# ── JSON processing ───────────────────────────────────────────────────────────
if echo "$COMMAND" | grep -qE 'cat[[:space:]]+[^|]+\.json[^|]*\|[[:space:]]*jq'; then
    block "Use Read tool to load JSON, then parse natively" \
          "Avoid: cat file.json | jq '...'  →  Instead: Read file.json"
fi
if echo "$COMMAND" | grep -qE 'jq[[:space:]].*select.*\|.*\{' || \
   echo "$COMMAND" | grep -qE 'jq[[:space:]].*\|.*\|.*\|'; then
    block "Use Read tool + native parsing instead of complex jq pipeline" \
          "Simple jq one-liners (jq '.field') are OK; multi-stage pipelines are not"
fi

exit 0
