#!/bin/bash
# Pre-tool-use hook to enforce native tool usage over Bash alternatives
# Called before every tool execution with: TOOL_NAME TOOL_ARGS

TOOL_NAME="$1"
TOOL_ARGS="$2"

# Only validate Bash tool usage
if [[ "$TOOL_NAME" != "Bash" ]]; then
    exit 0
fi

# Extract the command from JSON args (tool args are JSON-encoded)
COMMAND=$(echo "$TOOL_ARGS" | jq -r '.command // empty' 2>/dev/null)

if [[ -z "$COMMAND" ]]; then
    # Fallback if not JSON or jq fails - check raw args
    COMMAND="$TOOL_ARGS"
fi

# Check for heredoc patterns (file creation)
if echo "$COMMAND" | grep -qE '(cat[[:space:]]+>|cat.*<<|echo.*>>|echo.*>)'; then
    echo "❌ BLOCKED: Use Write tool instead of cat/echo with redirects"
    echo "   Rule: Create files with Write, not heredocs or shell redirects"
    exit 1
fi

# Check for inline scripts (Python, Ruby, etc.)
if echo "$COMMAND" | grep -qE '(python[0-9]?[[:space:]]+<<|ruby[[:space:]]+<<|node[[:space:]]+<<|perl[[:space:]]+<<)'; then
    echo "❌ BLOCKED: Use Write tool to create script file, then execute it"
    echo "   Rule: Write → create .py/.rb/.js file, then Bash → run it"
    exit 1
fi

# Check for commands that have native tool alternatives
# Only check at start of command (allowing these in pipes/subcommands is OK)
if echo "$COMMAND" | grep -qE '^[[:space:]]*(cat|head|tail|less|bat)[[:space:]]'; then
    echo "❌ BLOCKED: Use Read tool instead of $BASH_REMATCH"
    echo "   Rule: Read files with Read tool, not cat/head/tail/less"
    exit 1
fi

if echo "$COMMAND" | grep -qE '^[[:space:]]*(grep|rg|ag|ack)[[:space:]]'; then
    echo "❌ BLOCKED: Use Grep tool instead of grep/rg/ag"
    echo "   Rule: Search file contents with Grep, not grep commands"
    exit 1
fi

if echo "$COMMAND" | grep -qE '^[[:space:]]*(find|ls.*-R|tree)[[:space:]]'; then
    echo "❌ BLOCKED: Use Glob tool instead of find/ls -R/tree"
    echo "   Rule: Find files with Glob, not find/ls commands"
    exit 1
fi

if echo "$COMMAND" | grep -qE '^[[:space:]]*(sed|awk)[[:space:]].*-i'; then
    echo "❌ BLOCKED: Use Edit tool instead of sed/awk for file editing"
    echo "   Rule: Edit files with Edit tool, not sed/awk"
    exit 1
fi

# Check for JSON processing anti-patterns
# Block: cat *.json | jq (should use Read tool instead)
if echo "$COMMAND" | grep -qE 'cat[[:space:]]+[^|]+\.json[^|]*\|[[:space:]]*jq'; then
    echo "❌ BLOCKED: Use Read tool to load JSON, then parse/filter directly"
    echo "   Rule: Read JSON file → parse natively, don't pipe cat to jq"
    echo "   Avoid: cat file.json | jq '...'"
    echo "   Instead: Read file.json → filter/transform → output results"
    exit 1
fi

# Block: complex multi-stage jq pipelines with selects/maps (>2 pipes inside jq expression)
# This catches patterns like: jq '.[] | select(...) | {...}' which should be Read + native parsing
if echo "$COMMAND" | grep -qE 'jq[[:space:]].*select.*\|.*\{' || \
   echo "$COMMAND" | grep -qE 'jq[[:space:]].*\|.*\|.*\|'; then
    echo "❌ BLOCKED: Complex jq pipeline detected - use Read tool + native parsing instead"
    echo "   Rule: Read JSON → parse/filter/transform directly, avoid multi-stage jq"
    echo "   Complex jq pipelines trigger permission prompts and are harder to review"
    echo "   Simple jq one-liners (jq '.field') are OK in scripts"
    exit 1
fi

# Allow the command
exit 0
