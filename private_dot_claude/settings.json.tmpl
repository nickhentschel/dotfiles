{
{{- if .isWork }}
  "awsAuthRefresh": "aws sso login --profile zillow-sandbox",
{{- end }}
  "env": {
{{- if .isWork }}
    "AWS_PROFILE": "zillow-sandbox",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_REGION": "us-west-2",
    "DISABLE_PROMPT_CACHING": "0",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "global.anthropic.claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "global.anthropic.claude-haiku-4-5-20251001",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "global.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "global.anthropic.claude-opus-4-7",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "Claude Opus 4.7",
{{- else }}
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "claude-opus-4-7-20260115",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "Claude Opus 4.7",
{{- end }}
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write(/tmp/*)",
      "WebFetch",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(chezmoi cd:*)",
      "Bash(chezmoi apply:*)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi data:*)",
      "Bash(~/.config/tmux/claude-tmux.sh:*)",
      "Bash(~/.config/tmux/claude-notify.sh:*)",
      "Bash(tmux display:*)",
      "Bash(tmux show-options:*)",
      "Bash(tmux list-panes:*)",
      "Bash(tmux capture-pane:*)",
      "Bash(tmux list-keys:*)",
      "Bash(tmux source-file:*)",
      "Bash(tmux split-window:*)",
      "Bash(tmux set-option:*)",
      "Bash(tmux kill-pane:*)",
      "Bash(tmux display-message:*)",
      "Bash(tmux -V)",
      "Bash(brew list:*)",
      "Bash(brew search:*)",
      "Bash(brew info:*)",
      "Bash(brew install:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm list:*)",
      "Bash(yarn:*)",
      "Bash(make:*)",
      "Bash(defaults read:*)",
      "Bash(osascript:*)",
      "Bash(env)",
      "Bash(nvim --headless:*)",
      "Bash(rtk git add:*)",
      "Bash(rtk git commit:*)",
      "Bash(rtk git push:*)",
      "Bash(rtk git status:*)",
      "Bash(rtk git diff:*)",
      "Bash(rtk git log:*)",
      "Bash(rtk git branch:*)",
      "Bash(rtk git show:*)",
      "Bash(rtk chezmoi cd:*)",
      "Bash(rtk chezmoi apply:*)",
      "Bash(rtk chezmoi diff:*)",
      "Bash(rtk chezmoi data:*)",
      "Bash(rtk tmux display:*)",
      "Bash(rtk tmux show-options:*)",
      "Bash(rtk tmux list-panes:*)",
      "Bash(rtk tmux capture-pane:*)",
      "Bash(rtk tmux list-keys:*)",
      "Bash(rtk tmux source-file:*)",
      "Bash(rtk tmux split-window:*)",
      "Bash(rtk tmux set-option:*)",
      "Bash(rtk tmux kill-pane:*)",
      "Bash(rtk tmux display-message:*)",
      "Bash(rtk tmux -V)",
      "Bash(rtk brew list:*)",
      "Bash(rtk brew search:*)",
      "Bash(rtk brew info:*)",
      "Bash(rtk brew install:*)",
      "Bash(rtk npm install:*)",
      "Bash(rtk npm run:*)",
      "Bash(rtk npm list:*)",
      "Bash(rtk yarn:*)",
      "Bash(rtk make:*)",
      "Bash(rtk defaults read:*)",
      "Bash(rtk osascript:*)",
      "Bash(rtk env)",
      "Bash(rtk nvim --headless:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)"
{{- if .isWork }},
      "mcp__glean_default__search",
      "mcp__glean_default__chat",
      "mcp__glean_default__employee_search",
      "mcp__glean_default__read_document",
      "mcp__glean_default__read_memory",
      "mcp__plugin_slack_slack__slack_read_user_profile",
      "mcp__plugin_slack_slack__slack_search_public",
      "mcp__plugin_slack_slack__slack_read_thread",
      "mcp__plugin_slack_slack__slack_read_channel",
      "mcp__plugin_slack_slack__slack_search_channels",
      "mcp__plugin_slack_slack__slack_search_users"
{{- end }}
    ],
    "defaultMode": "default",
    "bash": {
      "alwaysAllowCommands": [
        "echo",
        "wc",
        "sort",
        "uniq",
        "cut",
        "tr",
        "which",
        "date",
        "pwd",
        "whoami",
        "basename",
        "dirname",
        "rtk"
      ],
      "alwaysAllowPatterns": [
{{- if .isWork }}
        "^acli jira workitem view .*",
        "^acli jira workitem search .*",
        "^acli jira workitem list .*",
        "^acli jira workitem attachment list .*",
        "^acli jira workitem comment list .*",
        "^acli jira workitem link list-types$",
        "^acli jira project list .*",
        "^acli jira project view .*",
{{- end }}
        "^git status",
        "^git diff",
        "^git log",
        "^git show",
        "^git branch($| -[alv])",
        "^brew list",
        "^brew search",
        "^brew info",
        "^npm list",
        "^make help",
        "^make --version",
        "^docker ps",
        "^docker images",
        "^docker logs",
        "^kubectl get",
        "^kubectl describe",
        "^rtk git status",
        "^rtk git diff",
        "^rtk git log",
        "^rtk git show",
        "^rtk git branch($| -[alv])",
        "^rtk brew list",
        "^rtk brew search",
        "^rtk brew info",
        "^rtk npm list",
        "^rtk make help",
        "^rtk make --version",
        "^rtk docker ps",
        "^rtk docker images",
        "^rtk docker logs",
        "^rtk kubectl get",
        "^rtk kubectl describe"
      ]
    }
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_SESSION_ID=\"${CLAUDE_SESSION_ID}\" CLAUDE_NOTIFICATION_TYPE=\"${CLAUDE_NOTIFICATION_TYPE}\" CLAUDE_TOOL_NAME=\"${CLAUDE_TOOL_NAME}\" ~/.config/tmux/claude-notify.sh"
          }
        ]
      }{{- if .isWork }},
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
      {{- end }}
    ],
    {{- if .isWork }}
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude",
            "timeout": 86400
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    {{- end }}
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-tool-usage.sh \"${CLAUDE_TOOL_NAME}\" \"${CLAUDE_TOOL_ARGS}\""
          },
          {
            "type": "command",
            "command": "CLAUDE_SESSION_ID=\"${CLAUDE_SESSION_ID}\" ~/.config/tmux/claude-tmux.sh state set working \"${CLAUDE_TOOL_NAME}\""
          }
        ]
      }{{- if not .isWork }},
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
      {{- end }}{{- if .isWork }},
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
      {{- end }}
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_SESSION_ID=\"${CLAUDE_SESSION_ID}\" ~/.config/tmux/claude-tmux.sh state set idle"
          }
        ]
      }{{- if .isWork }},
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
      {{- end }}
    ],
    {{- if .isWork }}
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    {{- end }}
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/claude-tmux.sh state clear"
          }
        ]
      }{{- if .isWork }},
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
      {{- end }}
    ]{{- if .isWork }},
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nickhe/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ]
    {{- end }}
  },
{{- if .isWork }}
  "statusLine": {
    "type": "command",
    "command": "/Users/nickhe/.vibe-island/bin/vibe-island-statusline"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
{{- end }}
  "syntaxHighlightingDisabled": false,
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.89",
  "skipAutoPermissionPrompt": true,
  "model": "sonnet"
}
