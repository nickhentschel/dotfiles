#-----------------------------------------------
# GENERAL SETTINGS
#-----------------------------------------------

# loud or quiet?
set-option -g visual-activity on
set-option -g visual-bell off
set-option -g visual-silence on
set-window-option -g monitor-activity off
set-option -g bell-action none

set -g extended-keys on

# Bind C-b to C-a, its just easier
set-option -g prefix C-a

set -g default-terminal "screen-256color"
set -ga terminal-overrides ",xterm-256color:Tc"

# set window and pane index to 1 (0 by default)
set-option -g base-index 1
setw -g pane-base-index 1

# Use vim keybindings in copy mode
setw -g mode-keys vi

# enable wm window titles
set -g set-titles on

# enable auto renaming
setw -g automatic-rename on

# wm window title string (uses statusbar variables)
set -g set-titles-string "#W"

# Scroll History
set -g history-limit 30000

# Lower escape timing from 500ms to 50ms for quicker response to scroll-buffer access.
set-option -s escape-time 10

# decrease repeat-time (default is 500ms)
set-option -g repeat-time 250

# Make mouse useful in copy mode
set -g mouse on

# Enable mouse selection to automatically copy to system clipboard
{{- if eq .chezmoi.os "linux" }}
bind-key -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel 'xclip -sel clip -i'
{{- else }}
bind-key -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel 'pbcopy'
{{- end }}

# Double-click to select word and copy
{{- if eq .chezmoi.os "linux" }}
bind-key -T copy-mode-vi DoubleClick1Pane select-pane \; send -X select-word \; send -X copy-pipe-and-cancel 'xclip -sel clip -i'
bind-key -n DoubleClick1Pane select-pane \; copy-mode -M \; send -X select-word \; send -X copy-pipe-and-cancel 'xclip -sel clip -i'
{{- else }}
bind-key -T copy-mode-vi DoubleClick1Pane select-pane \; send -X select-word \; send -X copy-pipe-and-cancel 'pbcopy'
bind-key -n DoubleClick1Pane select-pane \; copy-mode -M \; send -X select-word \; send -X copy-pipe-and-cancel 'pbcopy'
{{- end }}

# Triple-click to select line and copy
{{- if eq .chezmoi.os "linux" }}
bind-key -T copy-mode-vi TripleClick1Pane select-pane \; send -X select-line \; send -X copy-pipe-and-cancel 'xclip -sel clip -i'
bind-key -n TripleClick1Pane select-pane \; copy-mode -M \; send -X select-line \; send -X copy-pipe-and-cancel 'xclip -sel clip -i'
{{- else }}
bind-key -T copy-mode-vi TripleClick1Pane select-pane \; send -X select-line \; send -X copy-pipe-and-cancel 'pbcopy'
bind-key -n TripleClick1Pane select-pane \; copy-mode -M \; send -X select-line \; send -X copy-pipe-and-cancel 'pbcopy'
{{- end }}

#-----------------------------------------------
# BINDINGS
#-----------------------------------------------

# send the prefix to client inside window
bind-key a send-prefix

{{- if eq .chezmoi.os "linux" }}
bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel 'xclip -sel clip -i'
{{- else }}
bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel 'pbcopy'
{{- end }}
bind-key -T copy-mode-vi v send -X begin-selection
bind-key -T copy-mode-vi V send -X rectangle-toggle
bind-key -T copy-mode-vi Escape send -X cancel
bind-key -T copy-mode-vi 'PPage' send -X page-up
bind-key -T copy-mode-vi 'NPage' send -X page-down

# Toggle make pane full screen
bind = resize-pane -Z

# reload ~/.tmux.conf using PREFIX r
bind r source-file ~/.tmux.conf \; display "Reloaded!"

bind-key \\ split-window -h -c '#{pane_current_path}' # Split panes horizontally
bind-key - split-window -v -c '#{pane_current_path}' # Split panes vertically

# Smart pane switching with awareness of vim splits
# See: https://github.com/christoomey/vim-tmux-navigator
is_vim="ps -o state= -o comm= -t '#{pane_tty}' \
    | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|n?vim?x?)(diff)?$'"
bind-key -n C-h if-shell "$is_vim" "send-keys C-h"  "select-pane -L"
bind-key -n C-j if-shell "$is_vim" "send-keys C-j"  "select-pane -D"
bind-key -n C-k if-shell "$is_vim" "send-keys C-k"  "select-pane -U"
bind-key -n C-l if-shell "$is_vim" "send-keys C-l"  "select-pane -R"
bind-key -n C-\\ if-shell "$is_vim" "send-keys C-\\" "select-pane -l"

# Send command to all panes
bind-key C-x set-window-option synchronize-panes\; display-message "synchronize-panes is now #{?pane_synchronized,on,off}"

#-----------------------------------------------
# LOOK AND FEEL
#-----------------------------------------------

# status line
set -g status-justify left
set -g status-bg colour235
set -g status-interval 2

# window status
setw -g window-status-format         "#[fg=colour243] #W "
setw -g window-status-current-format "#[fg=white,bold] #W "

# session name on left, time on right
set -g status-left "#[fg=colour243]#S "
set -g status-right "#[fg=colour243]%H:%M"

#-----------------------------------------------
# CLAUDE CODE INTEGRATION
#-----------------------------------------------

# Status bar integration - show active Claude agents
set -g status-right-length 100
set -g status-right "#(~/.config/tmux/claude.tmux) #[fg=colour243]%H:%M"

# Key bindings for agent navigation (non-conflicting)
bind g run-shell "~/.config/tmux/claude-agent-list.sh"     # Go to agent (fzf selector)
bind n run-shell "~/.config/tmux/claude-agent-next.sh"     # Next waiting agent
bind s run-shell "~/.config/tmux/claude-agent-summary.sh"  # Summary popup
